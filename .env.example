# Google Cloud
GCP_PROJECT_ID=arxiv-summarizer-xyz
GCP_REGION=us-central1
FUNCTION_NAME=arxiv-summarizer

# Gemini — get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP sender account
# App Password setup: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the sender Gmail account)
GMAIL_USER=your.sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to deliver the daily digest
RECIPIENT_EMAIL=recipient@example.com
